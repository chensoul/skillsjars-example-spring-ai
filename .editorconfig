# EditorConfig - https://editorconfig.org
# 帮助在不同编辑器和 IDE 之间保持一致的编码风格

root = true

# 所有文件的基础配置
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Java 文件
[*.java]
indent_style = space
indent_size = 4

# XML 文件 (pom.xml, Maven 配置)
[*.xml]
indent_style = space
indent_size = 4

# Markdown 文件
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# YAML 文件
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Shell 脚本
[*.{sh,bash}]
indent_style = space
indent_size = 4

# Maven Wrapper 属性
[mvnw.properties]
indent_style = space
indent_size = 2

# Git 相关配置
[.gitignore]
indent_style = space
indent_size = 2

# 排除目录
[{node_modules,target,build,.idea,.git}/**]
trim_trailing_whitespace = false
